#!/bin/zsh
c=`echo 'conf\ndwm\ndwmstatus\nurxvt\nsxhkd\nfbrowse\nzshrc\nzprofile\nxinitrc\nxresources\nvimrc' | dmenu -p configure: -i -l 10`
if [[ $c == conf ]] ; then
	e="$EDITOR ~/.local/bin/conf"
elif [[ $c == dwm ]] ; then
	e="$EDITOR ~/.local/share/dwm/config.h && (cd ~/.local/share/dwm && ./build && mv dwm ~/.local/bin) ; read"
elif [[ $c == dwmstatus ]] ; then
	e="$EDITOR ~/.local/bin/dwmstatus"
elif [[ $c == sxhkd ]] ; then
	e="$EDITOR ~/.config/sxhkd/sxhkdrc"
elif [[ $c == urxvt ]] ; then
	e="$EDITOR ~/.urxvt/config && xrdb ~/.Xresources ; read"
elif [[ $c == fbrowse ]] ; then
	e="$EDITOR ~/.local/bin/fbrowse"
elif [[ $c == st ]] ; then
	e="$EDITOR ~/.local/share/st/config.h && (cd .local/share/st && make X11INC=/usr/include/X11 X11LIB=/usr/lib/X11 && make PREFIX=/usr DESTDIR=\"$PWD\" TERMINFO=\"~/.terminfo\" && mv st ~/.local/bin && tic -x st.info) ; read"
#elif [[ $c == statusbar ]] ; then
#	e="$EDITOR ~/.local/share/statusbar"
elif [[ $c == zshrc ]] ; then
	e="$EDITOR ~/.zshrc"
elif [[ $c == zprofile ]] ; then
	e="$EDITOR ~/.zprofile"
elif [[ $c == xinitrc ]] ; then
	e="$EDITOR ~/.xinitrc"
elif [[ $c == xresources ]] ; then
	e="$EDITOR ~/.Xresources && xrdb ~/.Xresources ; read"
elif [[ $c == vimrc ]] ; then
	e="$EDITOR ~/.vimrc"
else
	exit 0
fi
$TERMINAL -e $SHELL -c $e
