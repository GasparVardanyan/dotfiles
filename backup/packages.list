#!/bin/bash

# processor: intel, amd radeon
# boot-loader: grub
# display server: xorg
# wm: dwm
# terminal: st
# shell: zsh
# fonts: dejavu, hack, awesome
# browser: qutebrowser
# etc

base="amd-ucode intel-ucode linux-headers efibootmgr grub pulseaudio"
xorg="xf86-video-amdgpu xf86-video-intel xorg-server xorg-xinit xterm
xsel xorg-xbacklight xcompmgr sxhkd libinput"
cli="sudo tree dialog htop git translate-shell"
net="qutebrowser pdfjs net-tools wpa_supplicant dhclient"
wm="slock clipmenu feh numlockx pamixer scrot"
dwmdeps="libx11 libxinerama libxft freetype2 xorg-xrandr xorg-xsetroot"
stdeps="libxft libxext ncurses"
dmenudeps="freetype2 libxft libxinerama sh"
tabbeddeps="libx11"
statusbar="pamixer upower grep sed awk"
zsh="zsh zsh-completions bash-completion zsh-syntax-highlighting"
fs="dosfstools btrfs-progs"
arch="arch-wiki-docs arch-wiki-lite pkgfile reflector"
fonts="ttf-dejavu ttf-hack ttf-font-awesome otf-font-awesome"
media="imagemagick ffmpeg mupdf-gl cmus youtube-dl"
docs="man-db man-pages"
nvim="neovim ctags python-pynvim"

other="musl boost gdb valgrind radare2 radare2-cutter cppcheck
mupdf-tools texinfo"

# DWM
#   manual build (https://github.com/GasparVardanyan/dwm)
# ST
#   manual build (https://github.com/GasparVardanyan/st)
# DMENU
#   manual build (https://github.com/GasparVardanyan/dmenu)
# TABBED
#   manual build (https://github.com/GasparVardanyan/tabbed)

# TCC
#   manual build (git://repo.or.cz/tinycc.git)
#   configure --prefix=$HOME/.local --config-musl --cc=musl-gcc
# MANDOC
#   manual build (anoncvs@mandoc.bsd.lv:/cvs)
#   sed -i 's/\/usr\//\$HOME\/\./g' Makefile.local
# LIBULZ
#   manual build (https://github.com/rofl0r/libulz)
# LIBMOWGLI2
#   manual build (https://github.com/atheme/libmowgli-2)
#   configure --prefix=$HOME/.local
# LIBGD
#   manual build (https://github.com/libgd/libgd)
#   configure --prefix=$HOME/.local
# LIBSIXEL
#   manual build (https://github.com/saitoha/libsixel)
#   configure --prefix=$HOME/.local

packages="$base $xorg $cli $net $wm $dwmdeps $stdeps $dmenudeps
$tabbeddeps $statusbar $zsh $fs $arch $fonts $media $docs $nvim"

pacman -S $packages --needed
